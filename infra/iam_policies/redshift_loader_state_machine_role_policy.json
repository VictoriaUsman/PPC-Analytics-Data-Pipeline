{
  "_comment": "statemachine/redshift_load.asl.json execution role. Talks to the Redshift Data API only -- the actual S3 read for COPY is performed by Redshift itself under redshift_copy_role_policy.json, not this role. Scoped to one workgroup/database rather than redshift-serverless:*.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RunAndPollStatements",
      "Effect": "Allow",
      "Action": [
        "redshift-data:BatchExecuteStatement",
        "redshift-data:ExecuteStatement",
        "redshift-data:DescribeStatement"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {"redshift-data:workgroup-name": "${RedshiftWorkgroupName}"}
      }
    },
    {
      "Sid": "PublishValidationMetricsOnly",
      "Effect": "Allow",
      "Action": "cloudwatch:PutMetricData",
      "Resource": "*",
      "Condition": {"StringEquals": {"cloudwatch:namespace": "AdsPipeline/Ingestion"}}
    }
  ]
}
