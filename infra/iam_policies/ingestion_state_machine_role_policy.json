{
  "_comment": "statemachine/ads_ingestion.asl.json execution role. Invokes exactly the three ingestion Lambdas, runs the bronze_to_silver Glue job via the .sync integration (which needs GetJobRun/GetJobRuns/BatchStopJobRun beyond StartJobRun for Step Functions to poll it), and starts the nested redshift_load state machine via the .sync:2 integration (which needs the DescribeExecution/StopExecution plus the EventBridge rule permissions Step Functions manages automatically for that callback pattern).",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeIngestionLambdas",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": [
        "arn:aws:lambda:${AwsRegion}:${AwsAccountId}:function:ads-report-requester",
        "arn:aws:lambda:${AwsRegion}:${AwsAccountId}:function:ads-report-poller",
        "arn:aws:lambda:${AwsRegion}:${AwsAccountId}:function:ads-report-downloader"
      ]
    },
    {
      "Sid": "RunValidationGlueJobSync",
      "Effect": "Allow",
      "Action": ["glue:StartJobRun", "glue:GetJobRun", "glue:GetJobRuns", "glue:BatchStopJobRun"],
      "Resource": "arn:aws:glue:${AwsRegion}:${AwsAccountId}:job/bronze_to_silver"
    },
    {
      "Sid": "RunNestedRedshiftLoadStateMachineSync",
      "Effect": "Allow",
      "Action": ["states:StartExecution", "states:DescribeExecution", "states:StopExecution"],
      "Resource": [
        "arn:aws:states:${AwsRegion}:${AwsAccountId}:stateMachine:ads-redshift-load",
        "arn:aws:states:${AwsRegion}:${AwsAccountId}:execution:ads-redshift-load:*"
      ]
    },
    {
      "Sid": "ManageSyncCallbackEventRule",
      "Effect": "Allow",
      "Action": ["events:PutRule", "events:PutTargets", "events:DescribeRule"],
      "Resource": "arn:aws:events:${AwsRegion}:${AwsAccountId}:rule/StepFunctionsGetEventsForStepFunctionsExecutionRule"
    },
    {
      "Sid": "PublishBranchFailureMetricsOnly",
      "Effect": "Allow",
      "Action": "cloudwatch:PutMetricData",
      "Resource": "*",
      "Condition": {"StringEquals": {"cloudwatch:namespace": "AdsPipeline/Ingestion"}}
    }
  ]
}
