{
  "_comment": "glue_jobs/bronze_to_silver.py Glue job role. Reads bronze/, writes silver/ and rejected/ only (never back to bronze/), publishes only to the AdsPipeline/Validation CloudWatch namespace this job owns. Attach alongside AWS-managed AWSGlueServiceRole for the baseline Glue permissions (CloudWatch Logs, Glue Data Catalog) this policy does not duplicate.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadBronzeZone",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::${RawBucketName}/bronze/*"
    },
    {
      "Sid": "ListRawBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::${RawBucketName}",
      "Condition": {"StringLike": {"s3:prefix": ["bronze/*"]}}
    },
    {
      "Sid": "WriteSilverAndRejectedZones",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": [
        "arn:aws:s3:::${RawBucketName}/silver/*",
        "arn:aws:s3:::${RawBucketName}/rejected/*"
      ]
    },
    {
      "Sid": "EncryptWithBucketKmsKey",
      "Effect": "Allow",
      "Action": ["kms:GenerateDataKey", "kms:Decrypt"],
      "Resource": "${KmsKeyArn}"
    },
    {
      "Sid": "PublishValidationMetricsOnly",
      "Effect": "Allow",
      "Action": "cloudwatch:PutMetricData",
      "Resource": "*",
      "Condition": {"StringEquals": {"cloudwatch:namespace": "AdsPipeline/Validation"}}
    }
  ]
}
