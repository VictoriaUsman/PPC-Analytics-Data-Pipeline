RAW_BUCKET=ads-pipeline-raw-landing
PROFILES_CONFIG_PATH=config/profiles.yaml
LOOKBACK_DAYS=30

# LWA (Login with Amazon) OAuth application credentials — shared across all 26 profiles'
# refresh-token exchanges. NOT per-profile; the client app is the same, only the refresh
# token (stored in Secrets Manager, see config/profiles.yaml's secret_name field) differs
# per authorizing account.
ADS_LWA_CLIENT_ID=
ADS_LWA_CLIENT_SECRET=

# Region-specific Ads API hosts (profiles are pinned to one of these based on marketplace).
ADS_API_HOST_NA=advertising-api.amazon.com
ADS_API_HOST_EU=advertising-api-eu.amazon.com
ADS_API_HOST_FE=advertising-api-fe.amazon.com

# Redshift Serverless (referenced by the redshift_load state machine, not by any Lambda —
# credentials are never used directly; Step Functions calls redshift-data with an IAM role).
REDSHIFT_WORKGROUP=ads-pipeline-workgroup
REDSHIFT_DATABASE=ads_pipeline

# CloudWatch/alerting
METRIC_NAMESPACE=AdsPipeline/Validation
ALERT_SNS_TOPIC_ARN=
