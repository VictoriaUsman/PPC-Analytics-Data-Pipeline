# Env vars actually read by app code (os.environ, see common/secrets.py, lambda_handlers/) --
# for running/testing locally. Deploy-time infra config (Redshift workgroup/database, KMS key,
# bucket names, region hosts, alerting topic) is NOT env-var-driven: it's either a
# template.yaml CloudFormation Parameter substituted in at `sam deploy` time (see "Deploying
# (AWS SAM)" in README), or hardcoded in app code (e.g. connectors/ads_connector.py's
# REGION_HOSTS, glue_jobs/bronze_to_silver.py's METRIC_NAMESPACE) -- putting those here would
# imply they're configurable via env var, which they aren't.
RAW_BUCKET=ads-pipeline-raw-landing
PROFILES_CONFIG_PATH=config/profiles.yaml
LOOKBACK_DAYS=30

# LWA (Login with Amazon) OAuth application credentials — shared across all 26 profiles'
# refresh-token exchanges. NOT per-profile; the client app is the same, only the refresh
# token (stored in Secrets Manager, see config/profiles.yaml's secret_name field) differs
# per authorizing account.
ADS_LWA_CLIENT_ID=
ADS_LWA_CLIENT_SECRET=
